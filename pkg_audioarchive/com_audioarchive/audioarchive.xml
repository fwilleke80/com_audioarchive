<?xml version="1.0" encoding="UTF-8"?>
<extension type="component" method="upgrade">
    <name>COM_AUDIOARCHIVE</name>
    <version>0.9.2</version>
    <creationDate>2026-07-17</creationDate>
    <author>Frank Willeke</author>
    <copyright>Copyright (C) 2026 Frank Willeke.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <description>COM_AUDIOARCHIVE_XML_DESCRIPTION</description>
    <element>com_audioarchive</element>
    <namespace path="src">Willeke\Component\Audioarchive</namespace>
    <scriptfile>install.php</scriptfile>

    <install>
        <sql>
            <file driver="mysql" charset="utf8mb4">sql/install.mysql.utf8mb4.sql</file>
        </sql>
    </install>

    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8mb4">sql/uninstall.mysql.utf8mb4.sql</file>
        </sql>
    </uninstall>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <files folder="site">
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>layouts</folder>
        <folder>forms</folder>
    </files>

    <languages folder="site/language">
        <language tag="en-GB">en-GB/com_audioarchive.ini</language>
        <language tag="de-DE">de-DE/com_audioarchive.ini</language>
    </languages>

    <administration>
        <menu view="dashboard">COM_AUDIOARCHIVE</menu>
        <submenu>
            <menu link="option=com_audioarchive&amp;view=dashboard">COM_AUDIOARCHIVE_SUBMENU_DASHBOARD</menu>
            <menu link="option=com_audioarchive&amp;view=clips">COM_AUDIOARCHIVE_SUBMENU_CLIPS</menu>
            <menu link="option=com_categories&amp;view=categories&amp;extension=com_audioarchive">COM_AUDIOARCHIVE_SUBMENU_CATEGORIES</menu>
            <menu link="option=com_audioarchive&amp;view=upload">COM_AUDIOARCHIVE_SUBMENU_UPLOAD</menu>
            <menu link="option=com_audioarchive&amp;view=import">COM_AUDIOARCHIVE_SUBMENU_IMPORT</menu>
            <menu link="option=com_audioarchive&amp;view=maintenance">COM_AUDIOARCHIVE_SUBMENU_MAINTENANCE</menu>
        </submenu>
        <files folder="administrator">
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <folder>forms</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
        </files>
        <languages folder="administrator/language">
            <language tag="en-GB">en-GB/com_audioarchive.ini</language>
            <language tag="en-GB">en-GB/com_audioarchive.sys.ini</language>
            <language tag="de-DE">de-DE/com_audioarchive.ini</language>
            <language tag="de-DE">de-DE/com_audioarchive.sys.ini</language>
        </languages>
    </administration>

    <media destination="com_audioarchive" folder="media">
        <filename>joomla.asset.json</filename>
        <folder>css</folder>
        <folder>js</folder>
    </media>
</extension>
