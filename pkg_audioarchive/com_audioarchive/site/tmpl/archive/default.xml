				<option value="uploaded">COM_AUDIOARCHIVE_FIELD_UPLOAD_DATE</option>
				<option value="recorded">COM_AUDIOARCHIVE_FIELD_RECORDING_DATE</option>
				<option value="title">JGLOBAL_TITLE</option>
				<option value="duration">COM_AUDIOARCHIVE_FIELD_DURATION</option>
			</field>
			<field name="archive_default_direction" type="list" label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_DIRECTION_LABEL" default="">
