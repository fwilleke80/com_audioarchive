				<option value="asc">JGLOBAL_ORDER_ASCENDING</option>
				<option value="desc">JGLOBAL_ORDER_DESCENDING</option>
			</field>
			<field name="archive_default_limit" type="number" label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_LIMIT_LABEL" default="" min="1" max="200" />
		</fieldset>
		<fieldset name="filters" label="COM_AUDIOARCHIVE_CONFIG_ARCHIVE_FILTERS_LABEL">
