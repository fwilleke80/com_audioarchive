<?xml version="1.0" encoding="UTF-8"?>
<metadata>
	<layout title="COM_AUDIOARCHIVE_ARCHIVE_MENU_TITLE">
		<message>COM_AUDIOARCHIVE_ARCHIVE_MENU_DESC</message>
	</layout>
	<fields name="params">
		<fieldset name="basic" label="JGLOBAL_FIELDSET_BASIC">
			<field name="archive_category_restriction" type="category" extension="com_audioarchive" published="1" label="COM_AUDIOARCHIVE_MENU_CATEGORY_RESTRICTION_LABEL" default="0">
				<option value="0">JALL</option>
			</field>
			<field name="archive_tag_restriction" type="tag" multiple="true" label="COM_AUDIOARCHIVE_MENU_TAG_RESTRICTION_LABEL" />
			<field name="archive_default_ordering" type="list" label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_ORDERING_LABEL" default="">
