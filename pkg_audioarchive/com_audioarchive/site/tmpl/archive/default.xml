			<field name="archive_show_category_filter" type="list" label="COM_AUDIOARCHIVE_CONFIG_SHOW_CATEGORY_FILTER_LABEL" default=""><option value="">JGLOBAL_USE_GLOBAL</option><option value="1">JSHOW</option><option value="0">JHIDE</option></field>
			<field name="archive_show_tag_filter" type="list" label="COM_AUDIOARCHIVE_CONFIG_SHOW_TAG_FILTER_LABEL" default=""><option value="">JGLOBAL_USE_GLOBAL</option><option value="1">JSHOW</option><option value="0">JHIDE</option></field>
			<field name="archive_show_duration_filter" type="list" label="COM_AUDIOARCHIVE_CONFIG_SHOW_DURATION_FILTER_LABEL" default=""><option value="">JGLOBAL_USE_GLOBAL</option><option value="1">JSHOW</option><option value="0">JHIDE</option></field>
			<field name="archive_show_recorded_filter" type="list" label="COM_AUDIOARCHIVE_CONFIG_SHOW_RECORDED_FILTER_LABEL" default=""><option value="">JGLOBAL_USE_GLOBAL</option><option value="1">JSHOW</option><option value="0">JHIDE</option></field>
			<field name="archive_show_uploaded_filter" type="list" label="COM_AUDIOARCHIVE_CONFIG_SHOW_UPLOADED_FILTER_LABEL" default=""><option value="">JGLOBAL_USE_GLOBAL</option><option value="1">JSHOW</option><option value="0">JHIDE</option></field>
		</fieldset>
		<fieldset name="columns" label="COM_AUDIOARCHIVE_CONFIG_ARCHIVE_COLUMNS_LABEL">
			<field name="archive_column_play" type="list" label="COM_AUDIOARCHIVE_COLUMN_PLAY" default=""><option value="">JGLOBAL_USE_GLOBAL</option><option value="1">JSHOW</option><option value="0">JHIDE</option></field>
			<field name="archive_column_title" type="list" label="COM_AUDIOARCHIVE_COLUMN_TITLE" default=""><option value="">JGLOBAL_USE_GLOBAL</option><option value="1">JSHOW</option><option value="0">JHIDE</option></field>
			<field name="archive_column_category" type="list" label="COM_AUDIOARCHIVE_COLUMN_CATEGORY" default=""><option value="">JGLOBAL_USE_GLOBAL</option><option value="1">JSHOW</option><option value="0">JHIDE</option></field>
