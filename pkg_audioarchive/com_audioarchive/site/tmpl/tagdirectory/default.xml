<?xml version="1.0" encoding="UTF-8"?>
<metadata>
	<layout title="COM_AUDIOARCHIVE_TAG_DIRECTORY_MENU_TITLE">
		<message>COM_AUDIOARCHIVE_TAG_DIRECTORY_MENU_DESC</message>
	</layout>
	<fields name="params">
		<fieldset name="basic" label="JGLOBAL_FIELDSET_BASIC">
			<field
				name="tag_directory_intro_text"
				type="editor"
				label="COM_AUDIOARCHIVE_MENU_INTRO_TEXT_LABEL"
				description="COM_AUDIOARCHIVE_TAG_DIRECTORY_INTRO_TEXT_DESC"
				buttons="true"
				filter="\Joomla\CMS\Component\ComponentHelper::filterText"
			/>
			<field
				name="tag_directory_tags"
				type="tag"
				multiple="true"
				mode="nested"
				custom="false"
				layout="joomla.form.field.list-fancy-select"
				label="COM_AUDIOARCHIVE_TAG_DIRECTORY_TAGS_LABEL"
				description="COM_AUDIOARCHIVE_TAG_DIRECTORY_TAGS_DESC"
			/>
			<field
				name="tag_directory_archive_itemid"
				type="sql"
				query="SELECT m.id AS value, CONCAT(m.title, ' [', m.id, ']') AS text FROM #__menu AS m INNER JOIN #__extensions AS e ON e.extension_id = m.component_id WHERE m.client_id = 0 AND m.published = 1 AND e.type = 'component' AND e.element = 'com_audioarchive' AND m.link LIKE 'index.php?option=com_audioarchive&amp;view=archive%' ORDER BY m.title"
				key_field="value"
				value_field="text"
				default="0"
				label="COM_AUDIOARCHIVE_TAG_DIRECTORY_ARCHIVE_ITEM_LABEL"
				description="COM_AUDIOARCHIVE_TAG_DIRECTORY_ARCHIVE_ITEM_DESC"
			>
				<option value="0">COM_AUDIOARCHIVE_TAG_DIRECTORY_ARCHIVE_ITEM_AUTO</option>
			</field>
			<field
				name="tag_directory_hide_empty"
				type="radio"
				layout="joomla.form.field.radio.switcher"
				default="1"
				label="COM_AUDIOARCHIVE_TAG_DIRECTORY_HIDE_EMPTY_LABEL"
				description="COM_AUDIOARCHIVE_TAG_DIRECTORY_HIDE_EMPTY_DESC"
			>
				<option value="1">JYES</option>
				<option value="0">JNO</option>
			</field>
			<field
				name="tag_directory_ordering"
				type="list"
				default="title"
				label="COM_AUDIOARCHIVE_TAG_DIRECTORY_ORDERING_LABEL"
			>
				<option value="title">COM_AUDIOARCHIVE_TAG_DIRECTORY_ORDER_TITLE</option>
				<option value="count">COM_AUDIOARCHIVE_TAG_DIRECTORY_ORDER_COUNT</option>
				<option value="selected">COM_AUDIOARCHIVE_TAG_DIRECTORY_ORDER_SELECTED</option>
			</field>
		</fieldset>
		<fieldset name="display" label="COM_AUDIOARCHIVE_TAG_DIRECTORY_DISPLAY_FIELDSET">
			<field
				name="tag_directory_presentation"
				type="list"
				default="cards"
				label="COM_AUDIOARCHIVE_TAG_DIRECTORY_PRESENTATION_LABEL"
			>
				<option value="cards">COM_AUDIOARCHIVE_TAG_DIRECTORY_PRESENTATION_CARDS</option>
				<option value="list">COM_AUDIOARCHIVE_TAG_DIRECTORY_PRESENTATION_LIST</option>
				<option value="compact">COM_AUDIOARCHIVE_TAG_DIRECTORY_PRESENTATION_COMPACT</option>
			</field>
			<field
				name="tag_directory_show_descriptions"
				type="radio"
				layout="joomla.form.field.radio.switcher"
				default="1"
				label="COM_AUDIOARCHIVE_TAG_DIRECTORY_SHOW_DESCRIPTIONS_LABEL"
			>
				<option value="1">JSHOW</option>
				<option value="0">JHIDE</option>
			</field>
			<field
				name="tag_directory_show_counts"
				type="radio"
				layout="joomla.form.field.radio.switcher"
				default="0"
				label="COM_AUDIOARCHIVE_TAG_DIRECTORY_SHOW_COUNTS_LABEL"
				description="COM_AUDIOARCHIVE_TAG_DIRECTORY_SHOW_COUNTS_DESC"
			>
				<option value="1">JSHOW</option>
				<option value="0">JHIDE</option>
			</field>
		</fieldset>
	</fields>
</metadata>
