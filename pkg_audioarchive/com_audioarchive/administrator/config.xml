<?xml version="1.0" encoding="UTF-8"?>
<config>
    <fieldset name="general" label="COM_AUDIOARCHIVE_CONFIG_GENERAL_LABEL">
        <field
            name="default_category"
            type="category"
            extension="com_audioarchive"
            published="0,1"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_CATEGORY_LABEL"
            description="COM_AUDIOARCHIVE_CONFIG_DEFAULT_CATEGORY_DESC"
            default="0"
        >
            <option value="0">JOPTION_SELECT_CATEGORY</option>
        </field>
        <field
            name="default_access"
            type="accesslevel"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_ACCESS_LABEL"
            description="COM_AUDIOARCHIVE_CONFIG_DEFAULT_ACCESS_DESC"
            default="1"
        />
        <field
            name="default_state"
            type="list"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_STATE_LABEL"
            default="0"
            validate="options"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>
        <field
            name="default_ordering"
            type="list"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_ORDERING_LABEL"
            default="uploaded_at"
            validate="options"
        >
            <option value="uploaded_at">COM_AUDIOARCHIVE_FIELD_UPLOAD_DATE</option>
            <option value="recorded_at">COM_AUDIOARCHIVE_FIELD_RECORDING_DATE</option>
            <option value="title">JGLOBAL_TITLE</option>
        </field>
        <field
            name="default_direction"
            type="list"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_DIRECTION_LABEL"
            default="desc"
            validate="options"
        >
            <option value="asc">JGLOBAL_ORDER_ASCENDING</option>
            <option value="desc">JGLOBAL_ORDER_DESCENDING</option>
        </field>
        <field
            name="default_limit"
            type="number"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_LIMIT_LABEL"
            default="20"
            min="5"
            max="200"
            step="5"
        />
        <field name="enable_play_counts" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_PLAY_COUNTS_LABEL" default="1">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="enable_download_counts" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DOWNLOAD_COUNTS_LABEL" default="1">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>

    <fieldset name="storage" label="COM_AUDIOARCHIVE_CONFIG_STORAGE_LABEL">
        <field name="original_directory" type="text" label="COM_AUDIOARCHIVE_CONFIG_ORIGINAL_DIRECTORY_LABEL" description="COM_AUDIOARCHIVE_CONFIG_PATH_DESC" default="audioarchive/originals" />
        <field name="preview_directory" type="text" label="COM_AUDIOARCHIVE_CONFIG_PREVIEW_DIRECTORY_LABEL" description="COM_AUDIOARCHIVE_CONFIG_PATH_DESC" default="audioarchive/previews" />
        <field name="waveform_directory" type="text" label="COM_AUDIOARCHIVE_CONFIG_WAVEFORM_DIRECTORY_LABEL" description="COM_AUDIOARCHIVE_CONFIG_PATH_DESC" default="audioarchive/waveforms" />
        <field name="import_directory" type="text" label="COM_AUDIOARCHIVE_CONFIG_IMPORT_DIRECTORY_LABEL" description="COM_AUDIOARCHIVE_CONFIG_PATH_DESC" default="audioarchive/import" />
        <field name="recursive_import" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_RECURSIVE_IMPORT_LABEL" default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="allow_symlinks" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_ALLOW_SYMLINKS_LABEL" default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>

    <fieldset name="upload" label="COM_AUDIOARCHIVE_CONFIG_UPLOAD_LABEL">
        <field name="permitted_extensions" type="text" label="COM_AUDIOARCHIVE_CONFIG_EXTENSIONS_LABEL" default="m4a,mp4,aac,mp3,ogg,oga,opus,wav,flac,webm" />
        <field
            name="permitted_mime_types"
            type="text"
            label="COM_AUDIOARCHIVE_CONFIG_MIME_TYPES_LABEL"
            description="COM_AUDIOARCHIVE_CONFIG_MIME_TYPES_DESC"
            default="audio/mp4,audio/x-m4a,video/mp4,application/mp4,audio/aac,audio/x-aac,audio/x-hx-aac-adts,audio/mpeg,audio/mp3,audio/x-mp3,audio/ogg,audio/opus,application/ogg,audio/wav,audio/x-wav,audio/vnd.wave,audio/flac,audio/x-flac,audio/webm,video/webm"
        />
        <field name="maximum_file_size" type="number" label="COM_AUDIOARCHIVE_CONFIG_MAXIMUM_FILE_SIZE_LABEL" description="COM_AUDIOARCHIVE_CONFIG_ZERO_UNLIMITED_DESC" default="0" min="0" step="1" />
        <field name="maximum_duration" type="number" label="COM_AUDIOARCHIVE_CONFIG_MAXIMUM_DURATION_LABEL" description="COM_AUDIOARCHIVE_CONFIG_ZERO_UNLIMITED_DESC" default="0" min="0" step="1" />
        <field name="delete_inbox_after_import" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DELETE_INBOX_AFTER_IMPORT_LABEL" description="COM_AUDIOARCHIVE_CONFIG_DELETE_INBOX_AFTER_IMPORT_DESC" default="1">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="duplicate_policy" type="list" label="COM_AUDIOARCHIVE_CONFIG_DUPLICATE_POLICY_LABEL" default="warn" validate="options">
            <option value="ignore">COM_AUDIOARCHIVE_DUPLICATE_IGNORE</option>
            <option value="warn">COM_AUDIOARCHIVE_DUPLICATE_WARN</option>
            <option value="reject">COM_AUDIOARCHIVE_DUPLICATE_REJECT</option>
        </field>
        <field name="title_policy" type="list" label="COM_AUDIOARCHIVE_CONFIG_TITLE_POLICY_LABEL" default="embedded_filename" validate="options">
            <option value="embedded_filename">COM_AUDIOARCHIVE_TITLE_POLICY_EMBEDDED_FILENAME</option>
            <option value="filename">COM_AUDIOARCHIVE_TITLE_POLICY_FILENAME</option>
        </field>
        <field name="recorded_date_policy" type="list" label="COM_AUDIOARCHIVE_CONFIG_RECORDED_DATE_POLICY_LABEL" default="embedded_filesystem_import" validate="options">
            <option value="embedded_filesystem_import">COM_AUDIOARCHIVE_DATE_POLICY_EMBEDDED_FILESYSTEM_IMPORT</option>
            <option value="filesystem_import">COM_AUDIOARCHIVE_DATE_POLICY_FILESYSTEM_IMPORT</option>
            <option value="import">COM_AUDIOARCHIVE_DATE_POLICY_IMPORT</option>
        </field>
    </fieldset>


    <fieldset name="archive" label="COM_AUDIOARCHIVE_CONFIG_ARCHIVE_LABEL">
        <field name="archive_show_search" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_SEARCH_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_category_filter" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_CATEGORY_FILTER_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_tag_filter" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_TAG_FILTER_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_duration_filter" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_DURATION_FILTER_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_recorded_filter" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_RECORDED_FILTER_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_uploaded_filter" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_UPLOADED_FILTER_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_active_filters" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_ACTIVE_FILTERS_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_result_count" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_RESULT_COUNT_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_pagination" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_PAGINATION_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_page_size" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_PAGE_SIZE_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_show_empty_categories" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_SHOW_EMPTY_CATEGORIES_LABEL" description="COM_AUDIOARCHIVE_CONFIG_SHOW_EMPTY_CATEGORIES_DESC" default="0"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_filters_initial_state" type="list" label="COM_AUDIOARCHIVE_CONFIG_FILTERS_INITIAL_STATE_LABEL" description="COM_AUDIOARCHIVE_CONFIG_FILTERS_INITIAL_STATE_DESC" default="expanded" validate="options">
            <option value="expanded">COM_AUDIOARCHIVE_FILTERS_STATE_EXPANDED</option>
            <option value="collapsed">COM_AUDIOARCHIVE_FILTERS_STATE_COLLAPSED</option>
        </field>
        <field name="archive_allowed_page_sizes" type="text" label="COM_AUDIOARCHIVE_CONFIG_ALLOWED_PAGE_SIZES_LABEL" description="COM_AUDIOARCHIVE_CONFIG_ALLOWED_PAGE_SIZES_DESC" default="10,20,50,100" />
        <field name="archive_maximum_page_size" type="number" label="COM_AUDIOARCHIVE_CONFIG_MAXIMUM_PAGE_SIZE_LABEL" description="COM_AUDIOARCHIVE_CONFIG_MAXIMUM_PAGE_SIZE_DESC" default="200" min="1" max="1000" step="1" />
    </fieldset>

    <fieldset name="archive_columns" label="COM_AUDIOARCHIVE_CONFIG_ARCHIVE_COLUMNS_LABEL">
        <field name="archive_columns_note" type="note" label="COM_AUDIOARCHIVE_CONFIG_ARCHIVE_COLUMNS_NOTE_LABEL" description="COM_AUDIOARCHIVE_CONFIG_ARCHIVE_COLUMNS_DESC" class="alert alert-info" />
        <field name="archive_column_play" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_COLUMN_PLAY" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_column_title" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_COLUMN_TITLE" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_column_category" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_COLUMN_CATEGORY" default="0"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_column_duration" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_COLUMN_DURATION" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_column_recorded" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_COLUMN_RECORDED" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_column_uploaded" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_COLUMN_UPLOADED" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="archive_column_tags" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_COLUMN_TAGS" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
    </fieldset>

    <fieldset name="playback" label="COM_AUDIOARCHIVE_CONFIG_PLAYBACK_LABEL">
        <field name="allow_original_downloads" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_ALLOW_DOWNLOADS_LABEL" default="1"><option value="0">JNO</option><option value="1">JYES</option></field>
    </fieldset>

    <fieldset name="detail" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_LABEL">
        <field name="detail_show_duration" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_DURATION_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_category" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_CATEGORY_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_tags" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_TAGS_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_recorded" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_RECORDED_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_uploaded" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_UPLOADED_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_original_filename" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_FILENAME_LABEL" default="0"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_format" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_FORMAT_LABEL" default="0"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_codec" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_CODEC_LABEL" default="0"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_file_size" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_FILE_SIZE_LABEL" default="0"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_play_count" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_PLAY_COUNT_LABEL" default="0"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_download_count" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_DOWNLOAD_COUNT_LABEL" default="0"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
        <field name="detail_show_download" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DETAIL_DOWNLOAD_LABEL" default="1"><option value="0">JHIDE</option><option value="1">JSHOW</option></field>
    </fieldset>

    <fieldset name="processing" label="COM_AUDIOARCHIVE_CONFIG_PROCESSING_LABEL">
        <field name="automatic_executable_detection" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_AUTOMATIC_DETECTION_LABEL" default="1">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="ffmpeg_path" type="text" label="COM_AUDIOARCHIVE_CONFIG_FFMPEG_PATH_LABEL" default="" />
        <field name="ffprobe_path" type="text" label="COM_AUDIOARCHIVE_CONFIG_FFPROBE_PATH_LABEL" default="" />
        <field name="process_timeout" type="number" label="COM_AUDIOARCHIVE_CONFIG_PROCESS_TIMEOUT_LABEL" default="120" min="1" max="3600" />
        <field name="maximum_attempts" type="number" label="COM_AUDIOARCHIVE_CONFIG_MAXIMUM_ATTEMPTS_LABEL" default="3" min="1" max="20" />
    </fieldset>

    <fieldset name="uninstall" label="COM_AUDIOARCHIVE_CONFIG_UNINSTALL_LABEL">
        <field
            name="uninstall_notice"
            type="note"
            label="COM_AUDIOARCHIVE_CONFIG_UNINSTALL_NOTICE_LABEL"
            description="COM_AUDIOARCHIVE_CONFIG_UNINSTALL_NOTICE_DESC"
            class="alert alert-warning"
        />
        <field
            name="remove_media_on_uninstall"
            type="radio"
            layout="joomla.form.field.radio.switcher"
            label="COM_AUDIOARCHIVE_CONFIG_REMOVE_MEDIA_ON_UNINSTALL_LABEL"
            description="COM_AUDIOARCHIVE_CONFIG_REMOVE_MEDIA_ON_UNINSTALL_DESC"
            default="0"
            filter="integer"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field
            name="_uncategorised_seeded"
            type="hidden"
            default="0"
            filter="integer"
        />
    </fieldset>

    <fieldset name="permissions" label="JCONFIG_PERMISSIONS_LABEL">
        <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL" filter="rules" validate="rules" component="com_audioarchive" section="component" />
    </fieldset>
</config>
