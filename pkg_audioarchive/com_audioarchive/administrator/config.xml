<?xml version="1.0" encoding="UTF-8"?>
<config>
    <fieldset name="general" label="COM_AUDIOARCHIVE_CONFIG_GENERAL_LABEL">
        <field
            name="default_category"
            type="category"
            extension="com_audioarchive"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_CATEGORY_LABEL"
            description="COM_AUDIOARCHIVE_CONFIG_DEFAULT_CATEGORY_DESC"
            default="0"
        />
        <field
            name="default_access"
            type="accesslevel"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_ACCESS_LABEL"
            description="COM_AUDIOARCHIVE_CONFIG_DEFAULT_ACCESS_DESC"
            default="1"
        />
        <field
            name="default_state"
            type="list"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_STATE_LABEL"
            default="0"
            validate="options"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>
        <field
            name="default_ordering"
            type="list"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_ORDERING_LABEL"
            default="uploaded_at"
            validate="options"
        >
            <option value="uploaded_at">COM_AUDIOARCHIVE_FIELD_UPLOAD_DATE</option>
            <option value="recorded_at">COM_AUDIOARCHIVE_FIELD_RECORDING_DATE</option>
            <option value="title">JGLOBAL_TITLE</option>
        </field>
        <field
            name="default_direction"
            type="list"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_DIRECTION_LABEL"
            default="desc"
            validate="options"
        >
            <option value="asc">JGLOBAL_ORDER_ASCENDING</option>
            <option value="desc">JGLOBAL_ORDER_DESCENDING</option>
        </field>
        <field
            name="default_limit"
            type="number"
            label="COM_AUDIOARCHIVE_CONFIG_DEFAULT_LIMIT_LABEL"
            default="20"
            min="5"
            max="200"
            step="5"
        />
        <field name="enable_play_counts" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_PLAY_COUNTS_LABEL" default="1">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="enable_download_counts" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_DOWNLOAD_COUNTS_LABEL" default="1">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>

    <fieldset name="storage" label="COM_AUDIOARCHIVE_CONFIG_STORAGE_LABEL">
        <field name="original_directory" type="text" label="COM_AUDIOARCHIVE_CONFIG_ORIGINAL_DIRECTORY_LABEL" description="COM_AUDIOARCHIVE_CONFIG_PATH_DESC" default="audioarchive/originals" />
        <field name="preview_directory" type="text" label="COM_AUDIOARCHIVE_CONFIG_PREVIEW_DIRECTORY_LABEL" description="COM_AUDIOARCHIVE_CONFIG_PATH_DESC" default="audioarchive/previews" />
        <field name="waveform_directory" type="text" label="COM_AUDIOARCHIVE_CONFIG_WAVEFORM_DIRECTORY_LABEL" description="COM_AUDIOARCHIVE_CONFIG_PATH_DESC" default="audioarchive/waveforms" />
        <field name="import_directory" type="text" label="COM_AUDIOARCHIVE_CONFIG_IMPORT_DIRECTORY_LABEL" description="COM_AUDIOARCHIVE_CONFIG_PATH_DESC" default="audioarchive/import" />
        <field name="recursive_import" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_RECURSIVE_IMPORT_LABEL" default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="allow_symlinks" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_ALLOW_SYMLINKS_LABEL" default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
    </fieldset>

    <fieldset name="upload" label="COM_AUDIOARCHIVE_CONFIG_UPLOAD_LABEL">
        <field name="permitted_extensions" type="text" label="COM_AUDIOARCHIVE_CONFIG_EXTENSIONS_LABEL" default="m4a,mp4,aac,mp3,ogg,oga,opus,wav,flac,webm" />
        <field name="maximum_file_size" type="number" label="COM_AUDIOARCHIVE_CONFIG_MAXIMUM_FILE_SIZE_LABEL" description="COM_AUDIOARCHIVE_CONFIG_ZERO_UNLIMITED_DESC" default="0" min="0" step="1" />
        <field name="maximum_duration" type="number" label="COM_AUDIOARCHIVE_CONFIG_MAXIMUM_DURATION_LABEL" description="COM_AUDIOARCHIVE_CONFIG_ZERO_UNLIMITED_DESC" default="0" min="0" step="1" />
        <field name="duplicate_policy" type="list" label="COM_AUDIOARCHIVE_CONFIG_DUPLICATE_POLICY_LABEL" default="warn" validate="options">
            <option value="ignore">COM_AUDIOARCHIVE_DUPLICATE_IGNORE</option>
            <option value="warn">COM_AUDIOARCHIVE_DUPLICATE_WARN</option>
            <option value="reject">COM_AUDIOARCHIVE_DUPLICATE_REJECT</option>
        </field>
        <field name="title_policy" type="list" label="COM_AUDIOARCHIVE_CONFIG_TITLE_POLICY_LABEL" default="embedded_filename" validate="options">
            <option value="embedded_filename">COM_AUDIOARCHIVE_TITLE_POLICY_EMBEDDED_FILENAME</option>
            <option value="filename">COM_AUDIOARCHIVE_TITLE_POLICY_FILENAME</option>
        </field>
        <field name="recorded_date_policy" type="list" label="COM_AUDIOARCHIVE_CONFIG_RECORDED_DATE_POLICY_LABEL" default="embedded_filesystem_import" validate="options">
            <option value="embedded_filesystem_import">COM_AUDIOARCHIVE_DATE_POLICY_EMBEDDED_FILESYSTEM_IMPORT</option>
            <option value="filesystem_import">COM_AUDIOARCHIVE_DATE_POLICY_FILESYSTEM_IMPORT</option>
            <option value="import">COM_AUDIOARCHIVE_DATE_POLICY_IMPORT</option>
        </field>
    </fieldset>

    <fieldset name="processing" label="COM_AUDIOARCHIVE_CONFIG_PROCESSING_LABEL">
        <field name="automatic_executable_detection" type="radio" layout="joomla.form.field.radio.switcher" label="COM_AUDIOARCHIVE_CONFIG_AUTOMATIC_DETECTION_LABEL" default="1">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="ffmpeg_path" type="text" label="COM_AUDIOARCHIVE_CONFIG_FFMPEG_PATH_LABEL" default="" />
        <field name="ffprobe_path" type="text" label="COM_AUDIOARCHIVE_CONFIG_FFPROBE_PATH_LABEL" default="" />
        <field name="process_timeout" type="number" label="COM_AUDIOARCHIVE_CONFIG_PROCESS_TIMEOUT_LABEL" default="120" min="1" max="3600" />
        <field name="maximum_attempts" type="number" label="COM_AUDIOARCHIVE_CONFIG_MAXIMUM_ATTEMPTS_LABEL" default="3" min="1" max="20" />
    </fieldset>

    <fieldset name="permissions" label="JCONFIG_PERMISSIONS_LABEL">
        <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL" filter="rules" validate="rules" component="com_audioarchive" section="component" />
    </fieldset>
</config>
