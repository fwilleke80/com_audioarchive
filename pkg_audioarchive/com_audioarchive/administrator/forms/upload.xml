<?xml version="1.0" encoding="UTF-8"?>
<form>
    <fieldset name="metadata" label="COM_AUDIOARCHIVE_BULK_UPLOAD_METADATA_TITLE">
        <field
            name="catid"
            type="category"
            extension="com_audioarchive"
            published="0,1"
            label="JCATEGORY"
            required="true"
            default=""
        >
            <option value="">JOPTION_SELECT_CATEGORY</option>
        </field>
        <field
            name="tags"
            type="tag"
            label="JTAG"
            multiple="true"
            mode="ajax"
            custom="allow"
        />
        <field
            name="access"
            type="accesslevel"
            label="JFIELD_ACCESS_LABEL"
            default="1"
            required="true"
        />
        <field
            name="state"
            type="list"
            label="JSTATUS"
            default="0"
            required="true"
            validate="options"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>
        <field
            name="recorded_at"
            type="calendar"
            label="COM_AUDIOARCHIVE_BULK_UPLOAD_RECORDING_DATE"
            description="COM_AUDIOARCHIVE_BULK_UPLOAD_RECORDING_DATE_DESC"
            translateformat="true"
            showtime="true"
            filter="user_utc"
        />
    </fieldset>
</form>
